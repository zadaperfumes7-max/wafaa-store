{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A perfume product in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the perfume." },
        "description": { "type": "string", "description": "Description of the perfume." },
        "price": { "type": "number", "description": "Price of the perfume." },
        "imageUrl": { "type": "string", "description": "URL of the product image." },
        "category": { "type": "string", "description": "Category of the perfume." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was added." }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "User's email." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role." },
        "uid": { "type": "string", "description": "Firebase Auth UID." }
      },
      "required": ["email", "role", "uid"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of perfume products."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
